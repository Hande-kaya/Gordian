# Flask Configuration
SECRET_KEY=
JWT_SECRET_KEY=
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5004

# MongoDB Configuration
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>
MONGODB_DB=rfg-project

# Portal URLs
PORTAL_API_URL=http://localhost:5002
PORTAL_FRONTEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3003

# CORS Origins
CORS_ORIGINS=http://localhost:3003,http://localhost:3001

# Azure AD (Microsoft SSO)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:5004/api/auth/microsoft/callback
AZURE_AD_SCOPES=openid,profile,email

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5004/api/auth/google/callback

# B2C Frontend
B2C_FRONTEND_URL=http://localhost:3003

# Zepto Mail (Email sending)
ZEPTO_API_KEY=

# Google Cloud Document AI
GCP_PROJECT_ID=
GCP_LOCATION=eu
GCP_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# For cloud deployment (Render.com etc.) - base64 encoded GCP credentials
# GCP_CREDENTIALS_BASE64=

# OpenAI (for LLM extraction after OCR)
OPENAI_API_KEY=

# Stripe Payment
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_ID=
STRIPE_CREDIT_PACK_PRICE_ID=
